<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="94dp"
        android:background="@drawable/header_rounded"
        android:elevation="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/closeButtonEdit"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:layout_marginStart="15dp"
            android:background="@drawable/ic_clear_48px"
            android:contentDescription="@string/close_activity"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/edit_user_data"
            android:textColor="@color/black"
            android:textSize="20sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <LinearLayout
            android:layout_width="339dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:paddingTop="35dp"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="339dp"
                android:layout_height="78dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="17dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/name"
                    android:textColor="@color/black"
                    android:textSize="20sp" />

                <EditText
                    android:id="@+id/name_equipment_input"
                    android:layout_width="339dp"
                    android:layout_height="48dp"
                    android:autofillHints="emailAddress"
                    android:background="@drawable/rounded_square_border"
                    android:elevation="3dp"
                    android:hint="@string/enter_name"
                    android:inputType="textEmailAddress"
                    android:outlineProvider="background"
                    android:paddingLeft="16sp"
                    android:paddingRight="16sp"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/frameLayout3"
                android:layout_width="339dp"
                android:layout_height="78dp"
                android:layout_marginTop="21dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="17dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/last_name"
                    android:textColor="@color/black"
                    android:textSize="20sp" />

                <EditText
                    android:id="@+id/lastNameInput"
                    android:layout_width="339dp"
                    android:layout_height="48dp"
                    android:autofillHints="emailAddress"
                    android:background="@drawable/rounded_square_border"
                    android:elevation="3dp"
                    android:hint="@string/enter_last_name"
                    android:inputType="textEmailAddress"
                    android:outlineProvider="background"
                    android:paddingLeft="16sp"
                    android:paddingRight="16sp"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="339dp"
                android:layout_height="78dp"
                android:layout_marginTop="21dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="17dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/birthday_date"
                    android:textColor="@color/black"
                    android:textSize="20sp" />

                <EditText
                    android:id="@+id/dateInput"
                    android:layout_width="339dp"
                    android:layout_height="48dp"
                    android:autofillHints="none"
                    android:background="@drawable/rounded_square_border"
                    android:clickable="true"
                    android:drawableEnd="@drawable/ic_calendar"
                    android:elevation="3dp"
                    android:focusable="false"
                    android:hint="@string/enter_date"
                    android:inputType="date"
                    android:outlineProvider="background"
                    android:paddingLeft="16sp"
                    android:paddingRight="16sp"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="339dp"
                android:layout_height="78dp"
                android:layout_marginTop="21dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="17dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/email"
                    android:textColor="@color/black"
                    android:textSize="20sp" />

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="339dp"
                    android:layout_height="48dp"
                    android:autofillHints="emailAddress"
                    android:background="@drawable/rounded_square_border"
                    android:elevation="3dp"
                    android:hint="@string/enter_email"
                    android:inputType="textEmailAddress"
                    android:outlineProvider="background"
                    android:paddingLeft="16sp"
                    android:paddingRight="16sp"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="339dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="21dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="17dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/password"
                    android:textColor="@color/black"
                    android:textSize="20sp" />

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="339dp"
                    android:layout_height="48dp"
                    android:autofillHints="emailAddress"
                    android:background="@drawable/rounded_square_border"
                    android:elevation="3dp"
                    android:hint="@string/enter_password"
                    android:inputType="textPassword"
                    android:outlineProvider="background"
                    android:paddingLeft="16sp"
                    android:paddingRight="16sp"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="15dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/alert_password"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    app:drawableStartCompat="@drawable/ic_error_outline_15dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/deleteUserButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/shape_btn_delete_user"
                    android:clickable="true"
                    android:elevation="3dp"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/delete_user"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                </FrameLayout>

                <FrameLayout
                    android:id="@+id/savedChangesButton"
                    android:layout_width="match_parent"
                    android:layout_height="57dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/rounded_button"
                    android:clickable="true"
                    android:elevation="3dp"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/saved_changes"
                        android:textColor="@color/black"
                        android:textSize="24sp" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>





</androidx.constraintlayout.widget.ConstraintLayout>