<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="94dp"
        android:background="@drawable/header_rounded"
        android:elevation="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/closeButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:layout_marginStart="15dp"
            android:background="@drawable/ic_clear_48px"
            android:contentDescription="@string/close_activity"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:layout_gravity="center"
            android:text="@string/registration_user"
            android:textColor="@color/black"
            android:textSize="20sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp">

            <LinearLayout
                android:id="@+id/linearLayout2"
                android:layout_width="339dp"
                android:layout_height="wrap_content"

                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/header">

                <LinearLayout
                    android:id="@+id/frameLayout2"
                    android:layout_width="339dp"
                    android:layout_height="78dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/header">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="17dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/name"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                    <EditText
                        android:id="@+id/name_equipment_input"
                        android:layout_width="339dp"
                        android:layout_height="48dp"
                        android:autofillHints="emailAddress"
                        android:background="@drawable/rounded_square_border"
                        android:elevation="3dp"
                        android:hint="@string/enter_name"
                        android:inputType="textEmailAddress"
                        android:outlineProvider="background"
                        android:paddingLeft="16sp"
                        android:paddingRight="16sp"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frameLayout3"
                    android:layout_width="339dp"
                    android:layout_height="78dp"
                    android:layout_marginTop="21dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/frameLayout2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="17dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/last_name"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                    <EditText
                        android:id="@+id/lastNameInput"
                        android:layout_width="339dp"
                        android:layout_height="48dp"
                        android:autofillHints="emailAddress"
                        android:background="@drawable/rounded_square_border"
                        android:elevation="3dp"
                        android:hint="@string/enter_last_name"
                        android:inputType="textEmailAddress"
                        android:outlineProvider="background"
                        android:paddingLeft="16sp"
                        android:paddingRight="16sp"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frameLayout4"
                    android:layout_width="339dp"
                    android:layout_height="78dp"
                    android:layout_marginTop="21dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/frameLayout2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="17dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/birthday_date"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                    <EditText
                        android:id="@+id/dateInput"
                        android:layout_width="339dp"
                        android:layout_height="48dp"
                        android:autofillHints="none"
                        android:background="@drawable/rounded_square_border"
                        android:clickable="true"
                        android:drawableEnd="@drawable/ic_calendar"
                        android:elevation="3dp"
                        android:focusable="false"
                        android:hint="@string/enter_date"
                        android:inputType="date"
                        android:outlineProvider="background"
                        android:paddingLeft="16sp"
                        android:paddingRight="16sp"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/userRoleInput"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="21dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/user_role"
                        android:textColor="@color/black"
                        android:textSize="20sp" />


                    <FrameLayout
                        android:layout_width="339dp"
                        android:layout_height="48dp"
                        android:background="@drawable/rounded_square_border">

                        <Spinner
                            android:id="@+id/usersRoleSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent" />

                        <ImageView
                            android:id="@+id/year_arrow"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="@string/arrow"
                            android:src="@drawable/ic_keyboard_arrow_down_48px" />
                    </FrameLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="339dp"
                    android:layout_height="78dp"
                    android:layout_marginTop="21dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/frameLayout4">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="17dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/email"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                    <EditText
                        android:id="@+id/emailInput"
                        android:layout_width="339dp"
                        android:layout_height="48dp"
                        android:autofillHints="emailAddress"
                        android:background="@drawable/rounded_square_border"
                        android:elevation="3dp"
                        android:hint="@string/enter_email"
                        android:inputType="textEmailAddress"
                        android:outlineProvider="background"
                        android:paddingLeft="16sp"
                        android:paddingRight="16sp"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frameLayout6"
                    android:layout_width="339dp"
                    android:layout_height="78dp"
                    android:layout_marginTop="21dp"
                    android:layout_marginEnd="41dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/frameLayout5">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="17dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/password"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                    <EditText
                        android:id="@+id/passwordInput"
                        android:layout_width="339dp"
                        android:layout_height="48dp"
                        android:autofillHints="emailAddress"
                        android:background="@drawable/rounded_square_border"
                        android:elevation="3dp"
                        android:hint="@string/enter_password"
                        android:inputType="textPassword"
                        android:outlineProvider="background"
                        android:paddingLeft="16sp"
                        android:paddingRight="16sp"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>


            <FrameLayout
                android:id="@+id/savedButton"
                android:layout_width="339dp"
                android:layout_height="57dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/rounded_button"
                android:clickable="true"
                android:elevation="3dp"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/register"
                    android:textColor="@color/black"
                    android:textSize="24sp" />

            </FrameLayout>

        </LinearLayout>


    </ScrollView>




</androidx.constraintlayout.widget.ConstraintLayout>